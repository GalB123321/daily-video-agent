# Environment for the render worker (worker.py). Copy this file to .env and
# fill in the real values. These are not needed for the local daily run, only
# for the worker that renders queued jobs created by the shelly admin tile.
# Do not commit a filled in .env. No real secrets belong in this example file.

# Supabase project that holds the video_config, video_clips, and video_jobs tables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 bucket that stores clips and rendered outputs.
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=helly-media
